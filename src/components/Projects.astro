---
import SectionShell from './SectionShell.astro';
import { products, projects } from '../data/portfolio';
---

<SectionShell
  id="work"
  title="Products and shipped systems"
  lead="Real work from current portfolio: product builds, backend systems, mobile apps, and platform projects."
>
  <div class="mt-10 grid gap-5 lg:grid-cols-2">
    {
      products.map((product, index) => (
        <article class="reveal rounded-[32px] border border-[var(--line)] bg-[var(--text)] p-6 text-[var(--surface)] dark:bg-[var(--surface-elevated)] dark:text-[var(--text)]" style={`transition-delay:${index * 90}ms`}>
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="font-mono text-xs font-semibold text-[color-mix(in_srgb,var(--accent)_74%,white)]">{product.status}</p>
              <h3 class="mt-4 text-4xl font-black leading-none md:text-6xl">{product.title}</h3>
            </div>
            <a href={product.href} target={product.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer" class="rounded-full bg-[var(--surface)] px-4 py-2 text-sm font-bold text-[var(--text)] dark:bg-[var(--accent)] dark:text-[var(--surface)]">
              Open
            </a>
          </div>
          <p class="mt-6 max-w-xl text-base leading-7 text-[color-mix(in_srgb,var(--surface)_72%,transparent)] dark:text-[var(--text-muted)]">{product.summary}</p>
          <div class="mt-8 flex flex-wrap gap-2">
            {product.stack.map((item) => <span class="rounded-full border border-[color-mix(in_srgb,var(--surface)_18%,transparent)] px-3 py-1.5 font-mono text-xs dark:border-[var(--line)] dark:text-[var(--text-muted)]">{item}</span>)}
          </div>
        </article>
      ))
    }
  </div>

  <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {
      projects.map((project, index) => (
        <article class="reveal group rounded-[28px] border border-[var(--line)] bg-[color-mix(in_srgb,var(--surface-elevated)_82%,transparent)] p-5 transition hover:-translate-y-1 hover:border-[var(--accent)]" style={`transition-delay:${index * 55}ms`}>
          <div class="flex items-center justify-between gap-4">
            <p class="font-mono text-xs font-semibold text-[var(--accent)]">{project.type}</p>
          </div>
          <div class="p-6">
            <h3 class="mt-3 text-2xl font-semibold text-[var(--text)]">{project.title}</h3>
            <p class="mt-3 leading-7 text-[var(--text-muted)]">{project.summary}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              {project.stack.map((item) => <span class="rounded-full bg-[var(--surface-soft)] px-3 py-1.5 font-mono text-xs text-[var(--text)]">{item}</span>)}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</SectionShell>
