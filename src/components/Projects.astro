---
import SectionShell from './SectionShell.astro';
import { products, projects } from '../data/portfolio';
---

<SectionShell
  id="work"
  title="Products and shipped systems"
  lead="Real work from current portfolio: product builds, backend systems, mobile apps, and platform projects."
>
  <div class="mt-10 grid items-stretch gap-5 lg:grid-cols-3">
    {
      products.map((product, index) => (
        <article class="reveal premium-panel border-run motion-lift flex min-h-[360px] flex-col overflow-hidden rounded-[32px] border border-[var(--line)] bg-[var(--text)] p-6 text-[var(--surface)] dark:border-[color-mix(in_srgb,var(--accent)_34%,var(--line))] dark:bg-[linear-gradient(145deg,#0f1f3a_0%,#0a1426_58%,#07101d_100%)] dark:text-[var(--text)] dark:shadow-[0_28px_90px_color-mix(in_srgb,var(--accent)_16%,transparent)]" style={`transition-delay:${index * 90}ms`}>
          <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
              <p class="font-mono text-xs font-semibold text-[color-mix(in_srgb,var(--accent)_74%,white)] dark:text-[#7da7ff]">{product.status}</p>
              <h3 class="mt-4 text-4xl font-black leading-none md:text-5xl">{product.title}</h3>
            </div>
            <a href={product.href} target={product.href.startsWith('http') ? '_blank' : undefined} rel="noreferrer" class="motion-lift rounded-full bg-[var(--surface)] px-4 py-2 text-sm font-bold text-[var(--text)] dark:bg-[var(--accent)] dark:text-[var(--on-accent)]">
              Open
            </a>
          </div>
          <p class="mt-6 max-w-xl text-base leading-7 text-[color-mix(in_srgb,var(--surface)_72%,transparent)] dark:text-[#c3cee0]">{product.summary}</p>
          <div class="mt-auto flex flex-wrap gap-2 pt-8">
            {product.stack.map((item) => <span class="rounded-full border border-[color-mix(in_srgb,var(--surface)_18%,transparent)] px-3 py-1.5 font-mono text-xs dark:border-[color-mix(in_srgb,var(--accent)_28%,var(--line))] dark:bg-white/5 dark:text-[#d8e2f4]">{item}</span>)}
          </div>
        </article>
      ))
    }
  </div>

  <div class="mt-5 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
    {
      projects.map((project, index) => (
        <article class="reveal group border-run motion-lift overflow-hidden rounded-[28px] border border-[var(--line)] bg-[color-mix(in_srgb,var(--surface-elevated)_82%,transparent)] p-5" style={`transition-delay:${index * 55}ms`}>
          <div class="flex items-center justify-between gap-4">
            <p class="font-mono text-xs font-semibold text-[var(--accent)]">{project.type}</p>
          </div>
          <div class="p-6">
            <h3 class="mt-3 text-2xl font-semibold text-[var(--text)]">{project.title}</h3>
            <p class="mt-3 leading-7 text-[var(--text-muted)]">{project.summary}</p>
            <div class="mt-6 flex flex-wrap gap-2">
              {project.stack.map((item) => <span class="rounded-full bg-[var(--surface-soft)] px-3 py-1.5 font-mono text-xs text-[var(--text)]">{item}</span>)}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</SectionShell>
