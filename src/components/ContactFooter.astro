---
import { profile } from '../data/portfolio';
---

<footer id="contact" class="px-4 py-16 sm:px-6 lg:px-8">
  <div class="premium-panel border-run mx-auto max-w-7xl overflow-hidden rounded-[32px] border border-[var(--line)] bg-[var(--text)] p-6 text-[var(--surface)] md:p-10 dark:bg-[var(--surface-elevated)] dark:text-[var(--text)]">
    <div class="grid gap-10 lg:grid-cols-[1fr_auto] lg:items-end">
      <div>
        <p class="font-mono text-xs font-semibold uppercase tracking-[0.22em] text-[color-mix(in_srgb,var(--accent)_75%,white)] dark:text-[var(--accent-2)]">Contact</p>
        <h2 class="mt-5 max-w-3xl text-4xl font-extrabold leading-tight md:text-6xl">
          Let's build something.
        </h2>
        <p class="mt-5 max-w-2xl text-base leading-7 text-[color-mix(in_srgb,var(--surface)_72%,transparent)] dark:text-[var(--text-muted)]">
          Available for senior full-stack engineering, product builds, mobile apps, and performance-heavy backend work.
        </p>
      </div>
      <a
        href={`mailto:${profile.email}`}
        class="motion-lift inline-flex h-12 items-center justify-center rounded-full bg-[var(--surface)] px-6 text-sm font-bold text-[var(--text)] transition hover:-translate-y-0.5 active:translate-y-px dark:bg-[var(--accent)] dark:text-[var(--on-accent)]"
      >
        Get in touch
      </a>
    </div>
    <div class="mt-10 flex flex-col gap-3 border-t border-[color-mix(in_srgb,var(--surface)_18%,transparent)] pt-6 text-sm text-[color-mix(in_srgb,var(--surface)_66%,transparent)] sm:flex-row sm:items-center sm:justify-between dark:text-[var(--text-muted)]">
      <p>{profile.name} · {profile.site}</p>
      <div class="flex flex-wrap gap-4">
        <a href={profile.github} target="_blank" rel="noreferrer" class="hover:text-[var(--surface)] dark:hover:text-[var(--accent)]">GitHub</a>
        <a href={profile.linkedin} target="_blank" rel="noreferrer" class="hover:text-[var(--surface)] dark:hover:text-[var(--accent)]">LinkedIn</a>
        <a href={profile.product} target="_blank" rel="noreferrer" class="hover:text-[var(--surface)] dark:hover:text-[var(--accent)]">Keeep</a>
      </div>
    </div>
  </div>
</footer>
