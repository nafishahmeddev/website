---
import { ArrowUpRight, Code } from '@lucide/astro';
import ThemeToggle from './ThemeToggle.astro';
import { navItems, profile } from '../data/portfolio';
---

<header class="sticky top-0 z-30 px-3 py-3">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-3 rounded-full border border-[var(--line)] bg-[color-mix(in_srgb,var(--surface)_82%,transparent)] px-3 shadow-sm backdrop-blur-xl sm:px-4">
    <a href="/" class="inline-flex items-center gap-2 rounded-full px-2 py-2 font-mono text-sm font-semibold text-[var(--text)]">
      <span class="inline-flex size-8 items-center justify-center rounded-full bg-[var(--text)] text-[var(--surface)] dark:bg-[var(--accent)]">
        <Code size={17} strokeWidth={2} />
      </span>
      <span class="hidden sm:inline">{profile.name}</span>
      <span class="sm:hidden">Nafish</span>
    </a>
    <nav class="hidden items-center gap-1 lg:flex" aria-label="Primary">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="rounded-full px-3.5 py-2 text-sm font-semibold text-[var(--text-muted)] transition hover:bg-[var(--surface-elevated)] hover:text-[var(--text)]"
          >
            {item.label}
          </a>
        ))
      }
    </nav>
    <div class="flex items-center gap-2">
      <a
        href={`mailto:${profile.email}`}
        class="hidden h-10 items-center gap-2 rounded-full bg-[var(--text)] px-4 text-sm font-bold text-[var(--surface)] transition hover:-translate-y-0.5 active:translate-y-px md:inline-flex dark:bg-[var(--accent)] dark:text-[var(--surface)]"
      >
        Contact
        <ArrowUpRight size={16} strokeWidth={2} />
      </a>
      <ThemeToggle />
    </div>
  </div>
</header>
