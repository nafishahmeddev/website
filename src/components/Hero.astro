---
import {
  Activity,
  ArrowUpRight,
  BriefcaseBusiness,
  Cloud,
  DatabaseZap,
  Gauge,
  GitFork,
  Mail,
  MapPin,
  Smartphone,
  Users,
} from "@lucide/astro";
import { buildSignals, profile, stats } from "../data/portfolio";

const statIcons = [BriefcaseBusiness, Users, Gauge, GitFork];
const heroGrid = [
  { title: "API layers", text: "auth, roles, payments", icon: DatabaseZap },
  { title: "Admin tools", text: "dashboards, reports, ops", icon: Gauge },
  { title: "Mobile builds", text: "Expo, Flutter, stores", icon: Smartphone },
  { title: "Cloud deploys", text: "Docker, AWS, Redis", icon: Cloud },
];
---

<section class="relative overflow-hidden px-4 py-8 sm:px-6 lg:px-8 lg:py-12">
  <div class="kinetic-grid absolute inset-0 opacity-25" aria-hidden="true">
  </div>
  <div
    class="pointer-events-none absolute left-[15vw] top-24 h-px w-[70vw] bg-gradient-to-r from-transparent via-[var(--accent)] to-transparent opacity-30"
    data-parallax="-0.04"
    aria-hidden="true"
  >
  </div>
  <div
    class="mx-auto grid min-h-[calc(100dvh-72px)] max-w-7xl items-center gap-8 lg:grid-cols-[minmax(0,1fr)_440px]"
  >
    <div class="max-w-[46rem]">
      <div
        class="mb-5 flex flex-wrap items-center gap-3 text-sm text-[var(--text-muted)]"
      >
        <span
          class="motion-lift inline-flex items-center gap-2 rounded-full border border-[var(--line)] bg-[var(--surface-elevated)] px-3 py-2 font-mono text-xs font-semibold text-[var(--accent)]"
        >
          <BriefcaseBusiness size={16} />
          {profile.role}
        </span>
        <span
          class="motion-lift inline-flex items-center gap-2 rounded-full border border-[var(--line)] bg-[var(--surface-elevated)] px-3 py-2 font-mono text-xs font-semibold"
        >
          <MapPin size={16} />
          {profile.location}
        </span>
      </div>

      <h1
        class="max-w-4xl text-4xl font-black leading-[0.96] text-[var(--text)] sm:text-5xl md:text-6xl lg:text-7xl"
      >
        {profile.headline}
      </h1>

      <p
        class="mt-6 max-w-2xl text-base leading-7 text-[var(--text-muted)] md:text-lg md:leading-8"
      >
        {profile.intro}
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={`mailto:${profile.email}`}
          class="inline-flex h-12 items-center justify-center gap-2 rounded-full bg-[var(--text)] px-6 text-sm font-bold text-[var(--surface)] transition hover:-translate-y-0.5 active:translate-y-px dark:bg-[var(--accent)] dark:text-[var(--on-accent)]"
        >
          <Mail size={18} />
          Hire me
        </a>
        <a
          href={profile.github}
          target="_blank"
          rel="noreferrer"
          class="inline-flex h-12 items-center justify-center gap-2 rounded-full border border-[var(--line)] bg-[var(--surface-elevated)] px-6 text-sm font-bold text-[var(--text)] transition hover:-translate-y-0.5 active:translate-y-px"
        >
          <GitFork size={18} />
          GitHub
        </a>
      </div>
    </div>

    <aside
      class="reveal relative w-full max-w-[420px] justify-self-center lg:justify-self-end"
      style="transition-delay: 120ms"
    >
      <div
        class="signal-sweep premium-panel tilt-card relative overflow-hidden rounded-[28px] border border-[var(--line)] bg-[color-mix(in_srgb,var(--surface-elevated)_88%,transparent)] p-3 shadow-[0_28px_90px_color-mix(in_srgb,var(--accent)_14%,transparent)] backdrop-blur"
        data-tilt
      >
        <div
          class="relative rounded-[22px] bg-[var(--text)] p-5 text-[var(--surface)] dark:border dark:border-[color-mix(in_srgb,var(--accent)_22%,var(--line))] dark:bg-[color-mix(in_srgb,var(--accent)_12%,var(--surface-soft))] dark:text-[var(--text)]"
        >
          <div class="flex items-center justify-between gap-4">
            <p
              class="font-mono text-xs text-[color-mix(in_srgb,var(--surface)_64%,transparent)] dark:text-[var(--text-muted)]"
            >
              current focus
            </p>
            <ArrowUpRight size={18} />
          </div>
          <p class="mt-4 text-2xl font-black leading-[1.05] md:text-3xl">
            MERN stack. TypeScript. React Native. Indie SaaS.
          </p>
        </div>

        <div class="mt-3 grid grid-cols-2 gap-2">
          {
            heroGrid.map((item) => {
              const Icon = item.icon;
              return (
                <div class="motion-lift min-h-[104px] rounded-[18px] border border-[var(--line)] bg-[var(--surface)] p-4">
                  <span class="inline-flex size-8 items-center justify-center rounded-full bg-[var(--accent-soft)] text-[var(--accent)]">
                    <Icon size={17} />
                  </span>
                  <span class="mt-3 block text-sm font-black leading-tight text-[var(--text)]">
                    {item.title}
                  </span>
                  <p class="mt-1 text-xs font-semibold leading-4 text-[var(--text-muted)]">
                    {item.text}
                  </p>
                </div>
              );
            })
          }
        </div>

        <div class="mt-2 grid grid-cols-2 gap-2">
          {
            stats.slice(0, 2).map((stat, index) => {
              const Icon = statIcons[index] ?? Activity;
              return (
                <div class="motion-lift flex items-center gap-3 rounded-[18px] border border-[var(--line)] bg-[var(--surface)] px-3 py-3">
                  <span class="inline-flex size-8 items-center justify-center rounded-full bg-[var(--surface-soft)] text-[var(--accent)]">
                    <Icon size={17} />
                  </span>
                  <span>
                    <span class="block font-mono text-lg font-black leading-none text-[var(--text)]">
                      {stat.value}
                    </span>
                    <span class="mt-1 block text-[0.68rem] font-semibold leading-3 text-[var(--text-muted)]">
                      {stat.label}
                    </span>
                  </span>
                </div>
              );
            })
          }
        </div>
      </div>
    </aside>
  </div>

  <div
    class="premium-panel relative mx-auto mt-2 max-w-7xl overflow-hidden rounded-full border border-[var(--line)] bg-[color-mix(in_srgb,var(--surface-elevated)_82%,transparent)] py-3 backdrop-blur"
  >
    <div
      class="marquee-track flex w-max gap-8 px-4 font-mono text-xs font-semibold text-[var(--text-muted)]"
    >
      {[...buildSignals, ...buildSignals].map((item) => <span>{item}</span>)}
    </div>
  </div>
</section>
